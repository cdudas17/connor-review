# Copy this file to `.env` (gitignored) and fill in the values. The server
# loads `.env` on startup as a fallback — shell-exported variables still
# take precedence, so `~/.zshrc` exports win if both are set.

# Buildkite REST API token used by the CI drawer's per-row drill-in. Create
# at https://buildkite.com/user/api-access-tokens with at minimum the
# `read_builds` scope for the Gusto org.
BUILDKITE_API_TOKEN=

# URL of the local fix-ci-telemetry service. The root `npm run dev` script
# already sets this to http://127.0.0.1:5180 when launching the server;
# only needed here if you start the server independently.
# FIX_CI_TELEMETRY_URL=http://127.0.0.1:5180

# Calendar tab: no env wiring needed — install gcalcli locally instead.
#   brew install gcalcli   (or: pipx install gcalcli)
#   gcalcli init           (one-time browser sign-in)
